# ─────────────────────────────────────────────
#  HOME ASSISTANT DOCKER STACK — ENVIRONMENT
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── General ──────────────────────────────────
TZ=Asia/Kolkata
HOST_IP=192.168.1.100              # LAN IP of your Docker host (used for HomeKit advertise)

# ── Custom Domains ────────────────────────────
HA_DOMAIN=ha.yourdomain.com

# ── PostgreSQL (Home Assistant recorder) ──────
POSTGRES_DB=homeassistant
POSTGRES_USER=homeassistant
POSTGRES_PASSWORD=change_me_ha_db_password

# ── Logto OAuth — point at your existing Logto deployment ─────────────────
# Base URL of your already-running Logto (no trailing slash)
LOGTO_DOMAIN=auth.yourdomain.com
# Create an app in Logto Admin Console: Traditional Web
# Redirect URI: https://<HA_DOMAIN>/auth/oidc/callback
LOGTO_CLIENT_ID=your_ha_client_id
LOGTO_CLIENT_SECRET=your_ha_client_secret

# ── Mosquitto MQTT — both optional ────────────
# Leave empty to run without authentication.
MQTT_USER=
MQTT_PASSWORD=

# ── Watchtower ────────────────────────────────
# Cron schedule for automatic image updates (default: 04:00 daily)
WATCHTOWER_SCHEDULE=0 0 4 * * *

# ── Add-on ports (change if ports clash) ──────
#NODE_RED_PORT=1880
#ESPHOME_PORT=6052
#ZIGBEE2MQTT_PORT=8080
#ZWAVEJS_PORT=8091
#GRAFANA_PORT=3000
#CODE_SERVER_PORT=8443
#CODE_SERVER_PASSWORD=change_me_code_server_password
